@Library('main_shared') _

pipeline {
    agent any

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(daysToKeepStr: '2'))
    }

    environment {
        GIT_URL = 'https://github.com/shivashankarbukka402/3tire_app.git'
        GIT_BRANCH = 'main'
        GIT_CREDENTIALS = 'shivashankarbukka402'

        IMAGE_NAME = 'shiva9828/backend'
        IMAGE_TAG = 'latest'
        DOCKERFILE_BASE = 'Dockerfile'
        DOCKER_REGISTRY_CRED_ID = 'shia9828'

        SONAR_HOST_URL = 'http://13.232.176.30:9000'

        CREDS_ID = 'k8s_config'
        API_URL = 'https://3.110.186.242:6443'
        CONTEXT_NAME = 'k8s-admin'
        CLUSTER_NAME = 'k8s-cluster'
        USER_NAME = 'admin-sa'
    }

    stages {

        stage('CHECKOUT') {
            steps {
                script {
                    // ✅ FIXED: correct method name + correct argument order
                    gitcheckout(env.GIT_URL, env.GIT_BRANCH, env.GIT_CREDENTIALS)
                }
            }
        }

        stage('Sonar Code Quality check') {
            steps {
                script {
                    dir('backend') {
                        withCredentials([string(credentialsId: 'SONAR_TOKEN', variable: 'SONAR_TOKEN')]) {
                            // ✅ FIXED: removed Groovy interpolation warning
                            sh '''
                                sonar-scanner \
                                  -Dsonar.projectKey=backend \
                                  -Dsonar.sources=. \
                                  -Dsonar.host.url=$SONAR_HOST_URL \
                                  -Dsonar.token=$SONAR_TOKEN
                            '''
                        }
                    }
                }
            }
        }

        stage('Docker Build and Push') {
            steps {
                script {
                    sh 'ls -lrt'

                    dir('backend') {
                        // ✅ FIXED: proper variable scope
                        def dockerImage = docker.build("${IMAGE_NAME}:${IMAGE_TAG}", "-f ${DOCKERFILE_BASE} .")

                        docker.withRegistry('', "${DOCKER_REGISTRY_CRED_ID}") {
                            dockerImage.push()
                        }
                    }
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                sh '''
                    trivy image \
                    --severity HIGH,CRITICAL \
                    --format template \
                    --template "@/home/ubuntu/trivy/trivy_html.tpl" \
                    --output trivy_backend.html \
                    ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

        stage('Deploy K8S (ArgoCD)') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'argocd-cli-creds', usernameVariable: 'ARGO_USER', passwordVariable: 'ARGO_PASS')]) {
                        argoAppSyncWithCLI(
                            appName: 'backend',
                            argocdHost: '3.110.186.242:31556',
                            username: ARGO_USER,
                            password: ARGO_PASS,
                            insecure: true
                        )
                    }
                }
            }
        }
    }

    post {
        always {
            publishHTML(target: [
                allowMissing: false,
                alwaysLinkToLastBuild: false,
                keepAll: true,
                reportDir: '',
                reportFiles: 'trivy_backend.html',
                reportName: 'Backend Trivy Report'
            ])
            cleanWs()
        }

        success {
            echo "✅ Pipeline executed successfully"
        }

        failure {
            echo "❌ Pipeline failed - check logs"
        }
    }
}
